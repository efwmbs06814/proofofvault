{
  "name": "@proof-of-vault/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "ops:bootstrap-okx-agent-wallet": "tsx src/ops/bootstrap-okx-agent-wallet.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run --config ../../vitest.config.mjs --configLoader native",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@proof-of-vault/agent-runtime": "workspace:*",
    "@proof-of-vault/shared-types": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "pg": "^8.20.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "pg-mem": "^3.0.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
